# ElectroGrid API base URL (defaults to local backend)
VITE_API_URL=http://localhost:8080

# Marketing analytics — leave blank in dev; set in production.
# GA4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA4_ID=
# Meta (Facebook) Pixel ID, e.g. 1234567890123456
VITE_META_PIXEL_ID=
# TikTok Pixel ID, e.g. CXXXXXXXXXXXXXXXXXXX
VITE_TIKTOK_PIXEL_ID=

# Waitlist submission endpoint. Defaults to `${VITE_API_URL}/api/v1/waitlist`.
# Only set this if you want to point the form somewhere else (Formspree,
# Web3Forms, a staging backend, etc.).
VITE_WAITLIST_ENDPOINT=
